import java.util.Queue;
import java.util.LinkedList;

public class SistemaAtendimento {

    public static void main(String[] args) {

        // Criando filas
        Queue<String> filaPrioritaria = new LinkedList<>();
        Queue<String> filaNormal = new LinkedList<>();

        // Adicionando pessoas na fila prioritária
        filaPrioritaria.offer("Sr. José (80)");
        filaPrioritaria.offer("Dona Maria (70)");
        filaPrioritaria.offer("Sr. Pedro (65)");

        // Adicionando pessoas na fila normal
        filaNormal.offer("João");
        filaNormal.offer("Maria");
        filaNormal.offer("Carlos");
        filaNormal.offer("Ana");
        filaNormal.offer("Marcos");

        // Contadores
        int atendidosPrioritarios = 0;
        int atendidosNormais = 0;

        System.out.println("=== INICIANDO ATENDIMENTO ===\n");

        // Enquanto houver pessoas em alguma fila
        while (!filaPrioritaria.isEmpty() || !filaNormal.isEmpty()) {

            // Atende 2 prioritários
            for (int i = 0; i < 2; i++) {

                if (!filaPrioritaria.isEmpty()) {

                    String pessoa = filaPrioritaria.poll();

                    System.out.println(
                        "Atendendo (Prioritário): " + pessoa
                    );

                    atendidosPrioritarios++;

                } else {

                    System.out.println(
                        "Atendendo (Prioritário): (fila prioritária vazia)"
                    );
                }
            }

            // Atende 1 normal
            if (!filaNormal.isEmpty()) {

                String pessoa = filaNormal.poll();

                System.out.println(
                    "Atendendo (Normal): " + pessoa
                );

                atendidosNormais++;

            } else if (!filaPrioritaria.isEmpty()) {

                System.out.println(
                    "Atendendo (Normal): (fila normal vazia)"
                );
            }

            System.out.println();
        }

        // Total de atendimentos
        int total = atendidosPrioritarios + atendidosNormais;

        System.out.println("=== FIM DO ATENDIMENTO ===");

        System.out.println("Total atendidos: " + total);
        System.out.println("- Prioritários: " + atendidosPrioritarios);
        System.out.println("- Normais: " + atendidosNormais);
    }
}

