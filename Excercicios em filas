import java.util.PriorityQueue;

// Classe Tarefa
class Tarefa implements Comparable<Tarefa> {

    String nome;
    int prioridade;
    int ordemChegada;

    // Contador global para controlar ordem de chegada
    private static int contador = 0;

    // Construtor
    public Tarefa(String nome, int prioridade) {

        this.nome = nome;
        this.prioridade = prioridade;

        // Cada tarefa recebe um número crescente
        this.ordemChegada = contador++;
    }

    // Método para ordenar tarefas
    @Override
    public int compareTo(Tarefa outra) {

        // Primeiro ordena por prioridade
        if (this.prioridade != outra.prioridade) {

            return this.prioridade - outra.prioridade;
        }

        // Se prioridade igual, ordena por chegada
        return this.ordemChegada - outra.ordemChegada;
    }

    // Exibição formatada
    @Override
    public String toString() {

        return nome + " (Prioridade: " + prioridade + ")";
    }
}

public class SistemaTarefas {

    public static void main(String[] args) {

        // Criando fila de prioridade
        PriorityQueue<Tarefa> fila = new PriorityQueue<>();

        // Adicionando tarefas
        fila.offer(new Tarefa("Fazer backup", 2));
        fila.offer(new Tarefa("Reiniciar servidor", 1));
        fila.offer(new Tarefa("Limpar logs", 3));
        fila.offer(new Tarefa("Atualizar sistema", 1));
        fila.offer(new Tarefa("Responder emails", 2));

        // Exibindo tarefas adicionadas
        System.out.println("Tarefas adicionadas:");

        System.out.println("1. Fazer backup (Prioridade: 2)");
        System.out.println("2. Reiniciar servidor (Prioridade: 1)");
        System.out.println("3. Limpar logs (Prioridade: 3)");
        System.out.println("4. Atualizar sistema (Prioridade: 1)");
        System.out.println("5. Responder emails (Prioridade: 2)");

        // Processando tarefas
        System.out.println("\n=== EXECUTANDO TAREFAS ===");

        int ordem = 1;

        while (!fila.isEmpty()) {

            Tarefa tarefa = fila.poll();

            System.out.println(ordem + ". " + tarefa);

            ordem++;
        }
    }
}

