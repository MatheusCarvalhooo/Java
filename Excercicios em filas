import java.util.LinkedList;
import java.util.Scanner;

// Classe Documento
class Documento {

    int id;
    String nomeDocumento;
    String usuario;

    // Contador automático de IDs
    private static int contador = 1;

    // Construtor
    public Documento(String nomeDocumento, String usuario) {

        this.id = contador++;
        this.nomeDocumento = nomeDocumento;
        this.usuario = usuario;
    }

    // Exibição formatada
    @Override
    public String toString() {

        return id + "-" + nomeDocumento + "(" + usuario + ")";
    }
}

public class FilaImpressao {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        // Fila de impressão
        LinkedList<Documento> fila = new LinkedList<>();

        int opcao;

        do {

            // Menu
            System.out.println("\n--- FILA DE IMPRESSÃO ---");
            System.out.println("1 - Adicionar documento");
            System.out.println("2 - Imprimir próximo");
            System.out.println("3 - Cancelar documento");
            System.out.println("4 - Ver fila");
            System.out.println("5 - Sair");
            System.out.print("Escolha: ");

            opcao = scanner.nextInt();
            scanner.nextLine(); // Limpar buffer

            switch (opcao) {

                // Adicionar documento
                case 1:

                    System.out.print("Nome do documento: ");
                    String nomeDocumento = scanner.nextLine();

                    System.out.print("Usuário: ");
                    String usuario = scanner.nextLine();

                    Documento doc = new Documento(nomeDocumento, usuario);

                    fila.addLast(doc);

                    System.out.println(
                        "Documento #" + doc.id +
                        " adicionado: " +
                        doc.nomeDocumento +
                        " (" + doc.usuario + ")"
                    );

                    break;

                // Imprimir próximo
                case 2:

                    if (fila.isEmpty()) {

                        System.out.println("A fila está vazia.");

                    } else {

                        Documento impresso = fila.removeFirst();

                        System.out.println(
                            "Imprimindo documento #" +
                            impresso.id + ": " +
                            impresso.nomeDocumento +
                            " (" + impresso.usuario + ")"
                        );
                    }

                    break;

                // Cancelar documento
                case 3:

                    if (fila.isEmpty()) {

                        System.out.println("A fila está vazia.");

                    } else {

                        System.out.print("ID do documento a cancelar: ");
                        int idCancelar = scanner.nextInt();
                        scanner.nextLine();

                        boolean encontrado = false;

                        for (int i = 0; i < fila.size(); i++) {

                            if (fila.get(i).id == idCancelar) {

                                Documento removido = fila.remove(i);

                                System.out.println(
                                    "Documento #" +
                                    removido.id +
                                    " cancelado: " +
                                    removido.nomeDocumento +
                                    " (" + removido.usuario + ")"
                                );

                                encontrado = true;
                                break;
                            }
                        }

                        if (!encontrado) {

                            System.out.println("Documento não encontrado.");
                        }
                    }

                    break;

                // Ver fila
                case 4:

                    if (fila.isEmpty()) {

                        System.out.println("Fila vazia.");

                    } else {

                        System.out.println("Fila: " + fila);
                    }

                    break;

                // Sair
                case 5:

                    System.out.println("Encerrando sistema...");
                    break;

                // Opção inválida
                default:

                    System.out.println("Opção inválida.");
            }

        } while (opcao != 5);

        scanner.close();
    }
}

