import java.util.Queue;
import java.util.LinkedList;
import java.util.Scanner;

public class AtendimentoFila {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        // Criando a fila
        Queue<String> fila = new LinkedList<>();

        // Loop principal
        while (true) {

            System.out.print(
                "\nDigite um nome, 'atender', 'fila' ou 'sair': "
            );

            String comando = scanner.nextLine();

            // Encerrar programa
            if (comando.equalsIgnoreCase("sair")) {

                System.out.println("Encerrando...");
                break;
            }

            // Exibir fila
            else if (comando.equalsIgnoreCase("fila")) {

                if (fila.isEmpty()) {

                    System.out.println("A fila está vazia.");

                } else {

                    System.out.println("Fila atual: " + fila);
                }
            }

            // Atender próxima pessoa
            else if (comando.equalsIgnoreCase("atender")) {

                if (fila.isEmpty()) {

                    System.out.println("Não há pessoas na fila.");

                } else {

                    String pessoa = fila.poll();

                    System.out.println("Atendendo: " + pessoa);
                }
            }

            // Adicionar nome na fila
            else {

                fila.offer(comando);

