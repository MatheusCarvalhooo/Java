        System.out.println("=== SIMULAÇÃO CALL CENTER ===\n");

        // =========================
        // PROCESSAMENTO NÍVEL 1
        // =========================
        while (!filaNivel1.isEmpty()) {

            Chamada chamada = filaNivel1.poll();

            System.out.println(
                "Atendendo Chamada #" +
                chamada.id +
                ": " +
                chamada.descricao
            );

            // 70% de chance de resolver
            boolean resolvida = random.nextInt(100) < 70;

            if (resolvida) {

                System.out.println("  Nível 1: RESOLVIDA\n");

                resolvidasNivel1++;

            } else {

                System.out.println(
                    "  Nível 1: NÃO RESOLVIDA → escalando para Nível 2\n"
                );

                chamada.nivelAtual = 2;

                filaNivel2.offer(chamada);
            }
        }

        // =========================
        // PROCESSAMENTO NÍVEL 2
        // =========================
        while (!filaNivel2.isEmpty()) {

            Chamada chamada = filaNivel2.poll();

            System.out.println(
                "Atendendo Chamada #" +
                chamada.id +
                ": " +
                chamada.descricao
            );

            // 50% de chance de resolver
            boolean resolvida = random.nextInt(100) < 50;

            if (resolvida) {

                System.out.println("  Nível 2: RESOLVIDA\n");

                resolvidasNivel2++;

            } else {

                System.out.println(
                    "  Nível 2: NÃO RESOLVIDA → escalando para Nível 3\n"
                );

                chamada.nivelAtual = 3;

                filaNivel3.offer(chamada);
            }
        }

        // =========================
        // PROCESSAMENTO NÍVEL 3
        // =========================
        while (!filaNivel3.isEmpty()) {

            Chamada chamada = filaNivel3.poll();

            System.out.println(
                "Atendendo Chamada #" +
                chamada.id +
                ": " +
                chamada.descricao
            );

            // Nível 3 resolve tudo
            System.out.println("  Nível 3: RESOLVIDA\n");

            resolvidasNivel3++;
        }

        // =========================
        // ESTATÍSTICAS
        // =========================
        int total =
            resolvidasNivel1 +
            resolvidasNivel2 +
            resolvidasNivel3;

        System.out.println("=== ESTATÍSTICAS FINAIS ===");

        System.out.println(
            "Chamadas resolvidas no Nível 1: " +
            resolvidasNivel1
        );

        System.out.println(
            "Chamadas resolvidas no Nível 2: " +
            resolvidasNivel2
        );

        System.out.println(
            "Chamadas resolvidas no Nível 3: " +
            resolvidasNivel3
        );

        System.out.println("Total de chamadas: " + total);
    }
