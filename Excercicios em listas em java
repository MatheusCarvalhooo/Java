import java.util.ArrayList;
import java.util.Scanner;

public class RemoverDuplicados {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        // Lista para armazenar os números
        ArrayList<Integer> numeros = new ArrayList<>();

        int numero;

        // Entrada de números
        System.out.println("Digite números (0 para encerrar):");

        while (true) {

            numero = scanner.nextInt();

            // Encerra quando digitar 0
            if (numero == 0) {
                break;
            }

            numeros.add(numero);
        }

        // Removendo duplicados
        for (int i = 0; i < numeros.size(); i++) {

            for (int j = i + 1; j < numeros.size(); j++) {

                // Se encontrar número repetido
                if (numeros.get(i).equals(numeros.get(j))) {

                    numeros.remove(j);

                    j--; // Ajusta índice após remoção
                }
            }
        }

        // Exibindo lista final
        System.out.println("Lista final sem duplicados:");
        System.out.println(numeros);

        scanner.close();
    }
}

