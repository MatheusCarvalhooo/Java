import java.util.ArrayList;
import java.util.Scanner;

public class GerenciadorTarefas {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        // Listas de tarefas e prioridades
        ArrayList<String> descricoes = new ArrayList<>();
        ArrayList<Integer> prioridades = new ArrayList<>();

        int opcao;

        do {
            // Menu
            System.out.println("\n===== GERENCIADOR DE TAREFAS =====");
            System.out.println("1 - Adicionar tarefa");
            System.out.println("2 - Listar tarefas");
            System.out.println("3 - Concluir tarefa");
            System.out.println("4 - Sair");
            System.out.print("Escolha uma opção: ");

            opcao = scanner.nextInt();
            scanner.nextLine(); // Limpar buffer

            switch (opcao) {

                // Adicionar tarefa
                case 1:

                    System.out.print("Digite a descrição da tarefa: ");
                    String descricao = scanner.nextLine();

                    System.out.println("Prioridade:");
                    System.out.println("1 - Alta");
                    System.out.println("2 - Média");
                    System.out.println("3 - Baixa");
                    System.out.print("Escolha a prioridade: ");

                    int prioridade = scanner.nextInt();
                    scanner.nextLine();

                    descricoes.add(descricao);
                    prioridades.add(prioridade);

                    System.out.println("Tarefa adicionada com sucesso!");
                    break;

                // Listar tarefas por prioridade
                case 2:

                    System.out.println("\n===== LISTA DE TAREFAS =====");

                    if (descricoes.isEmpty()) {
                        System.out.println("Nenhuma tarefa cadastrada.");
                    } else {

                        // Exibe primeiro prioridade 1, depois 2 e 3
                        for (int p = 1; p <= 3; p++) {

                            for (int i = 0; i < descricoes.size(); i++) {

                                if (prioridades.get(i) == p) {

                                    String textoPrioridade = "";

                                    switch (p) {
                                        case 1:
                                            textoPrioridade = "Alta";
                                            break;

                                        case 2:
                                            textoPrioridade = "Média";
                                            break;

                                        case 3:
                                            textoPrioridade = "Baixa";
                                            break;
                                    }

                                    System.out.println(
                                        (i + 1) + " - " +
                                        descricoes.get(i) +
                                        " | Prioridade: " +
                                        textoPrioridade
                                    );
                                }
                            }
                        }
                    }
                    break;

                // Concluir tarefa
                case 3:

                    System.out.print("Digite o número da tarefa para concluir: ");
                    int numero = scanner.nextInt();
                    scanner.nextLine();

                    if (numero > 0 && numero <= descricoes.size()) {

                        descricoes.remove(numero - 1);
                        prioridades.remove(numero - 1);

                        System.out.println("Tarefa concluída e removida!");
                    } else {
                        System.out.println("Número inválido.");
                    }

                    break;

                // Sair
                case 4:
                    System.out.println("Encerrando programa...");
                    break;

                // Opção inválida
                default:
                    System.out.println("Opção inválida!");
            }

        } while (opcao != 4);

        scanner.close();
    }
}

